# SMTP Configuration Example
# DO NOT commit this file to version control after adding real credentials
# Copy this to .env and fill in your SMTP details

# SMTP Server Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_SENDER=your_email@gmail.com

# Usage:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your SMTP credentials
# 3. Load before running:
#    source .env
#    python -m ai_dispute_platform.pipeline.cli --notify recipient@example.com --watch ./pdfs/
#
# For Gmail:
#   - Enable 2-Factor Authentication
#   - Generate App Password: https://myaccount.google.com/apppasswords
#   - SMTP_PASSWORD = your generated app password (not your regular password)
#   - SMTP_SERVER = smtp.gmail.com
#   - SMTP_PORT = 587 (TLS) or 465 (SSL)
#   - SMTP_USER = your_full_email@gmail.com
#
# For Office 365:
#   - SMTP_SERVER = smtp.office365.com
#   - SMTP_PORT = 587
#   - SMTP_USER = your_email@company.com
#   - SMTP_PASSWORD = your_password
#
# For other providers, contact your email provider's SMTP documentation
